{
  "name": "auria",
  "version": "0.2.0",
  "description": "Accessibility + responsive-layout auditor: URL in -> narrated video, axe/layout/keyboard reports (MD/PDF/JSON/SARIF/JUnit), VPAT/ACR compliance, and dashboards out.",
  "type": "module",
  "author": "kkora <kora.kanchan@gmail.com>",
  "repository": { "type": "git", "url": "git+https://github.com/kkora/auria.git" },
  "bugs": { "url": "https://github.com/kkora/auria/issues" },
  "homepage": "https://github.com/kkora/auria#readme",
  "bin": {
    "auria": "bin/auria.mjs"
  },
  "main": "src/index.mjs",
  "exports": {
    ".": "./src/index.mjs"
  },
  "files": [
    "bin",
    "src",
    "assets",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "start": "node bin/auria.mjs",
    "test": "node --test \"test/**/*.test.mjs\"",
    "test:unit": "node --test \"test/unit/**/*.test.mjs\"",
    "test:integration": "node --test \"test/integration/**/*.test.mjs\"",
    "lint": "eslint ."
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "wcag",
    "section-508",
    "axe-core",
    "audit",
    "playwright",
    "nvda",
    "screen-reader",
    "sarif"
  ],
  "license": "MIT",
  "dependencies": {
    "@guidepup/guidepup": "^0.28.1",
    "axe-core": "^4.10.0",
    "ffmpeg-static": "^5.2.0",
    "playwright-core": "^1.49.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0"
  }
}
